@echo off
title EZ데이터허브 자동 동기화 프로그램
echo ======================================================
echo  데이터 동기화 및 위험 감지 알림을 시작합니다...
echo  실행 시간: %date% %time%
echo ======================================================

:: 1. 프로젝트 폴더로 이동 (절대 경로 사용)
cd /d "c:\김연아\Antigravity\현황대시보드"

:: 2. 데이터 수집기(collector.py) 실행
:: - API에서 데이터를 가져와 구글 시트에 업로드함
echo [1/2] 구글 시트 데이터 수집 중...
python "자동화 py\collector.py"

:: 3. 이메일 알림 체크
:: - 수집된 최신 데이터를 분석하여 위험 인원 발견 시 즉각 메일 발송
echo [2/2] 위험 인원 감지 및 이메일 알림 체크 중...
python "trigger_notif.py"

echo ======================================================
echo  동기화 및 알림 작업이 완료되었습니다. (%date% %time%)
echo ======================================================
:: 자동 실행 환경을 위해 pause는 제거합니다.
timeout /t 5
